{
  "manifest_version": 3,
  "name": "Cross-Platform Movie & TV Recommendation",
  "version": "2.0.0",
  "description": "Track your movie & TV show browsing and get personalized recommendations across streaming platforms",
  "author": "Senior Full-Stack Developer",
  
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "alarms"
  ],
  
  "host_permissions": [
    "https://www.hotstar.com/*",
    "https://www.primevideo.com/*",
    "https://www.netflix.com/*",
    "https://www.disneyplus.com/*",
    "https://www.hulu.com/*",
    "https://www.jiocinema.com/*",
    "https://www.zee5.com/*",
    "https://www.sonyliv.com/*",
    "https://www.crunchyroll.com/*",
    "https://api.themoviedb.org/*"
  ],
  
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Movie & TV Recommendations"
  },
  
  "background": {
    "service_worker": "background/background.js"
  },
  
  "content_scripts": [
    {
      "matches": [
        "https://www.hotstar.com/*",
        "https://www.primevideo.com/*",
        "https://www.netflix.com/*",
        "https://www.disneyplus.com/*",
        "https://www.hulu.com/*",
        "https://www.jiocinema.com/*",
        "https://www.zee5.com/*",
        "https://www.sonyliv.com/*",
        "https://www.crunchyroll.com/*"
      ],
      "js": [
        "utils/cache.js",
        "utils/i18n.js",
        "utils/api.js",
        "utils/storage.js",
        "utils/recommender.js",
        "content/platformDetectors.js",
        "ui/overlay.js",
        "content/content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  
  "icons": {
    "16": "assets/icons/icon-16.png",
    "48": "assets/icons/icon-48.png",
    "128": "assets/icons/icon-128.png"
  }
}
